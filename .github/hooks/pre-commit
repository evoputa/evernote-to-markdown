#!/usr/bin/env bash
# ============================================================
# PRE-COMMIT HOOK: Personal Data Scanner
# Blocks commits that contain personal/sensitive data patterns.
#
# Install: python .github/hooks/install-hooks.py
# Config:  .github/.sensitive-patterns
# Bypass:  git commit --no-verify (use with caution)
# ============================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color
BOLD='\033[1m'

PATTERNS_FILE="$(git rev-parse --show-toplevel)/.github/.sensitive-patterns"
BLOCKED=0
WARNINGS=0

echo ""
echo -e "${BOLD}[SCAN] Checking staged files for personal/sensitive data...${NC}"
echo ""

if [ ! -f "$PATTERNS_FILE" ]; then
    echo -e "${YELLOW}[WARN] No .sensitive-patterns file found. Skipping scan.${NC}"
    echo -e "${YELLOW}       Create one at: .github/.sensitive-patterns${NC}"
    exit 0
fi

# Get list of staged files (excluding deleted files and binary files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Read patterns file, skip comments and empty lines
while IFS= read -r line || [ -n "$line" ]; do
    # Skip comments and empty lines
    [[ "$line" =~ ^#.*$ ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue

    # Parse severity (BLOCK or WARN), default to BLOCK
    SEVERITY="BLOCK"
    PATTERN="$line"

    if [[ "$line" =~ ^WARN:[[:space:]]*(.*) ]]; then
        SEVERITY="WARN"
        PATTERN="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^BLOCK:[[:space:]]*(.*) ]]; then
        SEVERITY="BLOCK"
        PATTERN="${BASH_REMATCH[1]}"
    fi

    # Search staged file contents for this pattern
    for file in $STAGED_FILES; do
        # Skip binary files and the patterns file itself
        [[ "$file" == ".github/.sensitive-patterns" ]] && continue
        [[ "$file" == *.png ]] || [[ "$file" == *.jpg ]] || [[ "$file" == *.gif ]] || \
        [[ "$file" == *.ico ]] || [[ "$file" == *.woff ]] || [[ "$file" == *.db ]] && continue

        # Search the staged version of the file (not working directory)
        MATCHES=$(git show ":$file" 2>/dev/null | grep -inE "$PATTERN" 2>/dev/null)

        if [ -n "$MATCHES" ]; then
            if [ "$SEVERITY" == "BLOCK" ]; then
                echo -e "${RED}[BLOCKED]${NC} ${BOLD}$file${NC}"
                echo -e "  Pattern: ${RED}$PATTERN${NC}"
                echo "$MATCHES" | head -3 | while IFS= read -r match; do
                    echo -e "  ${RED}>>>${NC} $match"
                done
                MATCH_COUNT=$(echo "$MATCHES" | wc -l)
                if [ "$MATCH_COUNT" -gt 3 ]; then
                    echo -e "  ... and $((MATCH_COUNT - 3)) more matches"
                fi
                echo ""
                BLOCKED=$((BLOCKED + 1))
            else
                echo -e "${YELLOW}[WARNING]${NC} ${BOLD}$file${NC}"
                echo -e "  Pattern: ${YELLOW}$PATTERN${NC}"
                echo "$MATCHES" | head -2 | while IFS= read -r match; do
                    echo -e "  ${YELLOW}>>>${NC} $match"
                done
                echo ""
                WARNINGS=$((WARNINGS + 1))
            fi
        fi
    done

done < "$PATTERNS_FILE"

# Also check for common sensitive files being staged
SENSITIVE_FILES=(".env" ".env.local" ".env.production" "credentials.json" "secrets.json" \
    "id_rsa" "id_ed25519" "*.pem" "*.key" "token.txt" "auth.json")

for pattern in "${SENSITIVE_FILES[@]}"; do
    for file in $STAGED_FILES; do
        basename=$(basename "$file")
        if [[ "$basename" == $pattern ]]; then
            echo -e "${RED}[BLOCKED]${NC} ${BOLD}$file${NC}"
            echo -e "  Reason: ${RED}Sensitive file type ($basename)${NC}"
            echo ""
            BLOCKED=$((BLOCKED + 1))
        fi
    done
done

# Summary
echo -e "${BOLD}-------------------------------------------${NC}"
if [ $BLOCKED -gt 0 ]; then
    echo -e "${RED}${BOLD}COMMIT BLOCKED${NC}: $BLOCKED issue(s) found."
    echo -e "Fix the issues above, then try again."
    echo -e "${YELLOW}To bypass (emergency only): git commit --no-verify${NC}"
    echo ""
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}${BOLD}PASSED WITH WARNINGS${NC}: $WARNINGS warning(s)."
    echo -e "Review the warnings above. Commit proceeding."
    echo ""
    exit 0
else
    echo -e "${GREEN}${BOLD}CLEAN${NC}: No personal/sensitive data detected."
    echo ""
    exit 0
fi
